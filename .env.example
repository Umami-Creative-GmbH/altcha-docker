# Example environment configuration for altcha-docker
# Copy to .env and adjust values as needed

# REQUIRED: change this to a long random string, do NOT use the default
SECRET=change-me-to-a-long-random-string

# Optional settings
PORT=3000
EXPIREMINUTES=10
MAXRECORDS=1000
CORS_ORIGIN=*
ALGORITHM=PBKDF2/SHA-256
MAXNUMBER=5000
# Optional: override where demo server proxies /challenge and /verify (default: http://127.0.0.1:$PORT)
# API_BASE_URL=http://127.0.0.1:3000

# Enable a demo page on http://localhost:8080 when true
DEMO=false
