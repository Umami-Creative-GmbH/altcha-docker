# Example environment configuration for altcha-docker.
# Copy to .env and adjust values as needed.
# Do not use the built-in $ecret.key default in production; `$` has special
# meaning in Compose .env parsing, so this file uses a safe placeholder instead.

# API settings
SECRET=change-me-to-a-long-random-string
PORT=3000
EXPIREMINUTES=10
MAXRECORDS=1000
CORS_ORIGIN=*
ALGORITHM=PBKDF2/SHA-256
MAXNUMBER=5000

# Demo settings
API_BASE_URL=http://server:3000
DEMO_PORT=8080
